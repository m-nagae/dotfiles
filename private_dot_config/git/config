[user]
  name = Masahiro Nagae
  email = two.big.suns@gmail.com

[core]
  editor = nvim
  pager = delta

[delta]
  navigate = true
  dark = true

[interactive]
  diffFilter = delta --color-only

[init]
  defaultBranch = main

[push]
  autoSetupRemote = true

[pull]
  rebase = true

[fetch]
  prune = true

[merge]
  conflictStyle = zdiff3

[alias]
  clean-merged = "!git branch --merged | grep -v '\\*\\|main\\|master|develop' | xargs -n 1 git branch -d"

