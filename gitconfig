[user]
    name = Masahiro Nagae
    email = two.big.suns@gmail.com
[core]
    editor = nvim
    pager = less -r
    excludesFile = /Users/masahiro/.gitignore_global
[color]
    ui = auto
[merge]
    tool = vimdiff
[filter "lfs"]
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
    clean = git-lfs clean -- %f
[alias]
    cleanup = !git branch --merged | egrep -v '(^\\*|main|develop)' | xargs git branch -d
    create-backlog-issue-branch = "!git switch -c `pbpaste | sed -E 's# [^a-zA-Z0-9]*#/#' | sed -E 's/[^a-zA-Z0-9./_]+/-/g'`"
[pull]
    rebase = false
