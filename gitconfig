[user]
    name = Masahiro Nagae
    email = two.big.suns@gmail.com
[core]
    editor = nvim
    pager = less -r
[color]
    ui = auto
[merge]
    tool = vimdiff
[filter "lfs"]
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
    clean = git-lfs clean -- %f
[alias]
    cleanup = !git branch --merged | egrep -v '(^\\*|master|develop)' | xargs git branch -d
[pull]
    rebase = false
