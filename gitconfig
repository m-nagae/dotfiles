[core]
    editor = nvim

[merge]
    tool = vimdiff

[alias]
    cleanup = !git branch --merged | egrep -v '(^\\*|main|develop)' | xargs git branch -d

[commit]
    template = ~/.gitmessage.txt

[pull]
    rebase = false

[init]
    defaultBranch = main
